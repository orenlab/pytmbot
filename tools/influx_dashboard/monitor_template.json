          "colors": [
            {"id": "tmp-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "tmp-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "tmp-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
