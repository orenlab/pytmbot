[
  {
    "apiVersion": "influxdata.com/v2alpha1",
    "kind": "Dashboard",
    "metadata": {
      "name": "pytmbot-monitor-professional"
    },
    "spec": {
      "name": "pyTMbot Monitor",
      "charts": [
        {
          "axes": [
            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "cpu-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "cpu-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "cpu-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
          ],
          "geom": "line",
          "height": 4,
          "hoverDimension": "auto",
          "kind": "Xy",
          "legendColorizeRows": true,
          "legendOpacity": 1,
          "legendOrientationThreshold": 100000000,
          "name": "CPU Usage, %",
          "opacity": 1,
          "orientationThreshold": 100000000,
          "position": "overlaid",
          "queries": [
            {
              "query": "from(bucket: \"pytmbot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"system_metrics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"cpu_usage\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
            }
          ],
          "staticLegend": {
            "colorizeRows": true,
            "opacity": 1,
            "orientationThreshold": 100000000,
            "widthRatio": 1
          },
          "width": 6,
          "widthRatio": 1,
          "xPos": 0,
          "yPos": 0
        },
        {
          "axes": [
            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "mem-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "mem-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "mem-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
          ],
          "geom": "line",
          "height": 4,
          "hoverDimension": "auto",
          "kind": "Xy",
          "legendColorizeRows": true,
          "legendOpacity": 1,
          "legendOrientationThreshold": 100000000,
          "name": "Memory Usage, %",
          "opacity": 1,
          "orientationThreshold": 100000000,
          "position": "overlaid",
          "queries": [
            {
              "query": "from(bucket: \"pytmbot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"system_metrics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"memory_usage\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
            }
          ],
          "staticLegend": {
            "colorizeRows": true,
            "opacity": 1,
            "orientationThreshold": 100000000,
            "widthRatio": 1
          },
          "width": 6,
          "widthRatio": 1,
          "xPos": 6,
          "yPos": 0
        },
        {
          "axes": [
            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "load-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "load-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "load-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
          ],
          "geom": "line",
          "height": 4,
          "hoverDimension": "auto",
          "kind": "Xy",
          "legendColorizeRows": true,
          "legendOpacity": 1,
          "legendOrientationThreshold": 100000000,
          "name": "Load Average (1m/5m/15m)",
          "opacity": 1,
          "orientationThreshold": 100000000,
          "position": "overlaid",
          "queries": [
            {
              "query": "from(bucket: \"pytmbot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"system_metrics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"load_averages_1m\" or r[\"_field\"] == \"load_averages_2m\" or r[\"_field\"] == \"load_averages_3m\")\n  |> map(fn: (r) => ({ r with _field: if r._field == \"load_averages_1m\" then \"load_1m\" else if r._field == \"load_averages_2m\" then \"load_5m\" else \"load_15m\" }))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
            }
          ],
          "staticLegend": {
            "colorizeRows": true,
            "opacity": 1,
            "orientationThreshold": 100000000,
            "widthRatio": 1
          },
          "width": 6,
          "widthRatio": 1,
          "xPos": 0,
          "yPos": 4
        },
        {
          "axes": [
            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "smpl-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "smpl-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "smpl-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
          ],
          "geom": "line",
          "height": 4,
          "hoverDimension": "auto",
          "kind": "Xy",
          "legendColorizeRows": true,
          "legendOpacity": 1,
          "legendOrientationThreshold": 100000000,
          "name": "Monitor Samples / Minute",
          "opacity": 1,
          "orientationThreshold": 100000000,
          "position": "overlaid",
          "queries": [
            {
              "query": "from(bucket: \"pytmbot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"system_metrics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"cpu_usage\")\n  |> aggregateWindow(every: 1m, fn: count, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"samples_per_minute\" }))\n  |> yield(name: \"count\")"
            }
          ],
          "staticLegend": {
            "colorizeRows": true,
            "opacity": 1,
            "orientationThreshold": 100000000,
            "widthRatio": 1
          },
          "width": 6,
          "widthRatio": 1,
          "xPos": 6,
          "yPos": 4
        },
        {
          "axes": [
            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "dkr-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "dkr-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "dkr-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
          ],
          "geom": "line",
          "height": 4,
          "hoverDimension": "auto",
          "kind": "Xy",
          "legendColorizeRows": true,
          "legendOpacity": 1,
          "legendOrientationThreshold": 100000000,
          "name": "Docker Objects Count",
          "opacity": 1,
          "orientationThreshold": 100000000,
          "position": "overlaid",
          "queries": [
            {
              "query": "from(bucket: \"pytmbot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"system_metrics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"docker_containers_count\" or r[\"_field\"] == \"docker_images_count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
            }
