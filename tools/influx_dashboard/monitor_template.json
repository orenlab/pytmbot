          "height": 4,
          "hoverDimension": "auto",
          "kind": "Xy",
          "legendColorizeRows": true,
          "legendOpacity": 1,
          "legendOrientationThreshold": 100000000,
          "name": "Docker Running vs Stopped",
          "opacity": 1,
          "orientationThreshold": 100000000,
          "position": "overlaid",
          "queries": [
            {
              "query": "from(bucket: \"pytmbot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"system_metrics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"docker_running_containers\" or r[\"_field\"] == \"docker_stopped_containers\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
            }
          ],
          "staticLegend": {
            "colorizeRows": true,
            "opacity": 1,
            "orientationThreshold": 100000000,
            "widthRatio": 1
          },
          "width": 6,
          "widthRatio": 1,
          "xPos": 6,
          "yPos": 8
        },
        {
          "axes": [
            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "dsk-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "dsk-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
