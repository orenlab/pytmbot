            {"base": "10", "name": "x", "scale": "linear"},
            {"base": "10", "name": "y", "scale": "linear"}
          ],
          "colorizeRows": true,
          "colors": [
            {"id": "dks-01", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#31C0F6"},
            {"id": "dks-02", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#A500A5"},
            {"id": "dks-03", "name": "Nineteen Eighty Four", "type": "scale", "hex": "#FF7E27"}
          ],
