{# b_services_status.jinja2 #}
{{gear}} *System Services Status*
{% if has_systemd %}
*SystemD Services (Host):*
{{desktop_computer}} Total services: `{{ services_data.systemd.total_services }}`
{{green_circle}} Active: `{{ services_data.systemd.active_services }}`
{% if services_data.systemd.failed_services > 0 %}
{{red_circle}} Failed: `{{ services_data.systemd.failed_services }}`
{% endif %}
*Critical Services Status:*
{% for service_name, status in services_data.systemd.critical_services.items() %}
{% if status.exists %}
{% if status.active == 'active' %}
{{green_circle}} `{{ service_name }}`: {{status.active}}{% if status.enabled == 'enabled' %} (enabled){% endif %}{{ '' }}
{% elif status.active == 'failed' %}
{{red_circle}} `{{ service_name }}`: {{status.active}}
{% else %}
{{yellow_circle}} `{{ service_name }}`: {{status.active}}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}{% if has_alpine %}{% if has_systemd %}{% endif %}

*Alpine OpenRC Services:*
{{desktop_computer}} Total services: `{{ services_data.alpine.total_services }}`
{{green_circle}} Started: `{{ services_data.alpine.started_services }}`
{% if services_data.alpine.stopped_services > 0 %}
{{red_circle}} Stopped: `{{ services_data.alpine.stopped_services }}`
{% endif %}

*Services by Runlevel:*
{% for runlevel, services in services_data.alpine.services_by_runlevel.items() %}
📁 `{{ runlevel }}`:
{% for service in services.started[:3] %}
  {{green_circle}} {{ service }}
{% endfor %}
{% if services.stopped %}
{% for service in services.stopped[:2] %}
  {{red_circle}} {{ service }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

{% if has_docker %}
{% if has_systemd or has_alpine %}

{% endif %}
*Docker Services:*
{{whale}} Total containers: `{{ services_data.docker.total_containers }}`
{{green_circle}} Running: `{{ services_data.docker.running_containers }}`
{% if services_data.docker.stopped_containers > 0 %}
{{red_circle}} Stopped: `{{ services_data.docker.stopped_containers }}`
{% endif %}
{% if services_data.docker.unhealthy_containers > 0 %}
{{yellow_circle}} Unhealthy: `{{ services_data.docker.unhealthy_containers }}`
{% endif %}

*Container Services:*
{% for service in services_data.docker.services[:5] %}
{% if service.status == 'running' %}
{{green_circle}} `{{ service.name }}`: {{ service.status }}
{% elif service.status in ['exited', 'stopped'] %}
{{red_circle}} `{{ service.name }}`: {{ service.status }}
{% else %}
{{yellow_circle}} `{{ service.name }}`: {{ service.status }}
{% endif %}
   └ Image: `{{ service.image }}`
{% if service.health != 'unknown' %}
   └ Health: `{{ service.health }}`
{% endif %}
{% endfor %}
{% if services_data.docker.services|length > 5 %}

_... and {{ services_data.docker.services|length - 5 }} more containers_
{% endif %}
{% endif %}

{% if not has_systemd and not has_alpine and not has_docker %}
{{warning}} *No service information available*
SystemD, OpenRC, and Docker are not accessible from this container.
{% endif %}
